# ── Environment & Secrets ──────────────────────────
.env
.venv/
venv/
env/

# ── Python ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# ── Testing & Coverage ───────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── IDE ───────────────────────────────────────────────
.idea/
.vscode/

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Project Data & Artifacts ─────────────────────────
# Raw/processed data and trained models are regenerated by the
# pipeline scripts and are too large (or too environment-specific)
# to track in git. .gitkeep placeholders keep the folder structure
# itself versioned so a fresh clone has the expected directories.
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
models/*
!models/.gitkeep

# NOTE: reports/figures/ and reports/shap_biomarker_table.csv are
# intentionally NOT ignored -- the README embeds
# reports/figures/shap_beeswarm_vital_status.png directly, and it
# would render as a broken image on GitHub if this folder were
# excluded. These are committed results, not scratch output.

# ── Logs ──────────────────────────────────────────────
*.log